---
import Base from '../../layouts/Base-Claude.astro';
import { GLOSSARY } from '../../data/glossary-Claude';

const description =
  'A glossary of cemetery and burial terms: mausoleum, crypt, catacombs, columbarium, necropolis, heritage status, and more, defined in plain language.';

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'DefinedTermSet',
    name: 'Cemetery and burial glossary',
    description,
    url: new URL('/glossary/', Astro.site).href,
    hasDefinedTerm: GLOSSARY.map((t) => ({
      '@type': 'DefinedTerm',
      name: t.term,
      description: t.definition,
      url: new URL(`/glossary/#${t.slug}`, Astro.site).href,
      inDefinedTermSet: new URL('/glossary/', Astro.site).href,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Resting Places', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Glossary', item: new URL('/glossary/', Astro.site).href },
    ],
  },
];
---

<Base title="Glossary | Resting Places" description={description} jsonld={jsonld}>
  <h1>Glossary</h1>
  <p class="lede">
    Terms used across this directory to describe how cemeteries are built, organized, and recognized, from mausoleums
    and crypts to heritage designations. Where a term maps to a browsable category in the directory, the entry links there.
  </p>

  <ul class="chips">
    {GLOSSARY.map((t) => <a href={`#${t.slug}`}>{t.term}</a>)}
  </ul>

  {GLOSSARY.map((t) => (
    <section id={t.slug}>
      <h2>{t.term}</h2>
      <p>{t.definition}</p>
      {t.relatedHub && (
        <p class="note">
          See also: <a href={t.relatedHub.href}>{t.relatedHub.label}</a>. {t.relatedHub.note}
        </p>
      )}
    </section>
  ))}
</Base>
