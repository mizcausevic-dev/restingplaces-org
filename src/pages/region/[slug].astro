---
import { getCollection } from 'astro:content';
import HubPage from '../../components/HubPage-Claude.astro';
import { hubIntro } from '../../lib/hub-intro-Claude';

export async function getStaticPaths() {
  const all = await getCollection('cemeteries');
  const byRegion = new Map<string, any[]>();
  for (const c of all) {
    if (!c.data.region_slug) continue;
    if (!byRegion.has(c.data.region_slug)) byRegion.set(c.data.region_slug, []);
    byRegion.get(c.data.region_slug)!.push(c.data);
  }
  return [...byRegion.entries()].map(([slug, cems]) => ({
    params: { slug },
    props: { cems: cems.sort((a, b) => b.notable_interments_total - a.notable_interments_total) },
  }));
}
const { cems } = Astro.props;
const region = cems[0].region;
const country = cems[0].country;
const crumb = cems[0].country_slug ? { name: country, href: `/country/${cems[0].country_slug}/` } : null;
---

<HubPage
  title={`Cemeteries in ${region}${country ? `, ${country}` : ''} | Resting Places`}
  h1={`Cemeteries in ${region}`}
  intro={hubIntro(`in ${region}${country ? `, ${country}` : ''}`, cems)}
  path={`/region/${Astro.params.slug}/`}
  cems={cems}
  crumb={crumb}
/>
